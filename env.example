# ExamShield — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git. This file (.env.example) is safe to commit.

# MongoDB Atlas connection string
# Get from: Atlas dashboard → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/examshield?appName=examshield-cluster

# Gemini API key
# Get from: aistudio.google.com → API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Server port (default: 3000)
PORT=3000

# JWT secret — use a long random string, never reuse across environments
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# JWT expiry — 8h is good for exam sessions (students don't need persistent sessions)
JWT_EXPIRES_IN=8h

# Email sending — Nodemailer + Gmail App Password
# Get an App Password: Google Account → Security → 2-Step Verification → App Passwords
# (You must enable 2-Step Verification first, then generate an app-specific password)
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASS=your_16_char_app_password

# For production scale, swap emailService.js for AWS SES (same sendOTP/sendExamCode interface)
# AWS SES: ~₹7 per 1,000 emails, supports very high volume
